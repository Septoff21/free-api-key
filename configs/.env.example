# Free API Key —— 环境变量模板
# 复制此文件为 .env（已在 .gitignore 中排除），填入你自己的 key
# Copy this file to .env (already git-ignored), fill in your own keys
#
# 不是每个都需要填 / You don't need to fill in all of them
# 空着的 provider 会在 check-keys.mjs 中显示为 "not configured"

# ─── OpenRouter ───────────────────────────────────────────────────────────────
# 获取: https://openrouter.ai/keys
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── Google Gemini / AI Studio ────────────────────────────────────────────────
# 获取: https://aistudio.google.com/apikey
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Groq ─────────────────────────────────────────────────────────────────────
# 获取: https://console.groq.com/keys
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# ─── Cerebras ─────────────────────────────────────────────────────────────────
# 获取: https://cloud.cerebras.ai (注册后进 API Keys)
# Get key: https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# ─── GitHub Models ────────────────────────────────────────────────────────────
# 使用你的 GitHub Personal Access Token
# scope 需要: models:read (或使用经典 PAT)
# Use your GitHub PAT with models:read scope (or a classic PAT)
# Get token: https://github.com/settings/tokens
GITHUB_TOKEN=

# ─── Mistral La Plateforme ────────────────────────────────────────────────────
# 获取: https://console.mistral.ai/api-keys
# Get key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# ─── Cloudflare Workers AI ────────────────────────────────────────────────────
# 需要两个值 / Requires two values:
# Account ID: Cloudflare Dashboard → 右侧栏 Account ID
# API Token: https://dash.cloudflare.com/profile/api-tokens → Workers AI 模板
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ─── Ollama（本地 / Local）────────────────────────────────────────────────────
# 无需 key，只需本地运行 ollama serve
# No key needed, just run `ollama serve` locally
# 默认值通常正确，除非你改了端口
# Default is usually correct unless you changed the port
OLLAMA_BASE_URL=http://localhost:11434

# ─── Proxy（可选 / Optional）─────────────────────────────────────────────────
# 如果你在中国大陆，访问 Gemini / Groq 可能需要代理
# If you're in mainland China, you may need a proxy for Gemini / Groq
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
